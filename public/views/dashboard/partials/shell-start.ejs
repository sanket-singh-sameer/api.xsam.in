<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #f4efe4;
      --panel: #fef9f0;
      --card: #fffdf8;
      --ink: #1b1712;
      --soft: #6a5d4f;
      --accent: #c16016;
      --accent-dark: #8f430b;
      --border: #dac7ad;
      --ok: #0f766e;
      --err: #b91c1c;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100dvh;
      font-family: "Space Grotesk", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 15% 20%, #ffe0bd 0 18%, transparent 19%),
        radial-gradient(circle at 90% 25%, #d5ece5 0 17%, transparent 18%),
        linear-gradient(180deg, #f8f3e9 0%, #f3e9d8 100%);
      padding: 1rem 0.9rem;
    }

    .layout {
      width: min(1200px, 100%);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      gap: 1rem;
      animation: reveal 0.45s ease;
    }

    .sidebar {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 1rem;
      box-shadow: 0 14px 34px rgba(25, 18, 11, 0.1);
      padding: 1.1rem;
      position: sticky;
      top: 1rem;
      height: fit-content;
    }

    .brand {
      font-family: "Fraunces", serif;
      font-size: 1.45rem;
      margin-bottom: 0.2rem;
    }

    .welcome {
      color: var(--soft);
      font-size: 0.92rem;
      margin-bottom: 1rem;
    }

    .menu {
      display: grid;
      gap: 0.45rem;
      margin-bottom: 1rem;
    }

    .menu a {
      text-decoration: none;
      color: var(--ink);
      border: 1px solid var(--border);
      border-radius: 0.65rem;
      padding: 0.58rem 0.68rem;
      background: #fffaf3;
      font-weight: 600;
      transition: transform 0.18s ease, background-color 0.18s ease;
    }

    .menu a:hover {
      transform: translateX(2px);
      background: #fff3e3;
    }

    .menu a.active {
      background: #fde8cf;
      border-color: var(--accent);
      color: #6f3309;
    }

    .logout {
      width: 100%;
      border: none;
      border-radius: 0.7rem;
      padding: 0.62rem 0.8rem;
      background: var(--accent);
      color: #fff;
      font-weight: 700;
      cursor: pointer;
    }

    .main {
      display: grid;
      gap: 0.9rem;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 1rem;
      box-shadow: 0 11px 26px rgba(20, 17, 12, 0.08);
      padding: 1rem;
    }

    h1 {
      font-family: "Fraunces", serif;
      font-size: clamp(1.5rem, 2.9vw, 2.1rem);
      margin-bottom: 0.5rem;
    }

    .top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.7rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-block;
      text-decoration: none;
      border: 1px solid var(--accent);
      background: var(--accent);
      color: #fff;
      padding: 0.52rem 0.75rem;
      border-radius: 0.56rem;
      font-weight: 700;
      cursor: pointer;
      font-family: inherit;
      font-size: 0.95rem;
    }

    .btn.secondary {
      background: #fff;
      color: var(--accent);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.9rem;
    }

    .item-row {
      border-bottom: 1px solid var(--border);
      padding: 0.75rem 0;
    }

    .item-row:last-child {
      border-bottom: none;
    }

    .meta {
      color: var(--soft);
      font-size: 0.9rem;
      margin-top: 0.3rem;
      margin-bottom: 0.5rem;
    }

    .empty {
      color: var(--soft);
    }

    .field { margin-bottom: 0.75rem; }

    .field label {
      display: block;
      font-weight: 700;
      margin-bottom: 0.35rem;
      font-size: 0.92rem;
    }

    .field input,
    .field textarea,
    .field select {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 0.45rem;
      padding: 0.55rem 0.6rem;
      font-family: inherit;
      font-size: 0.95rem;
      background: #fff;
    }

    .field textarea {
      min-height: 130px;
      resize: vertical;
    }

    .status {
      margin-top: 0.75rem;
      min-height: 1.2rem;
      font-size: 0.9rem;
    }

    .status.ok { color: var(--ok); }
    .status.err { color: var(--err); }

    @media (max-width: 1080px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: static; }
    }

    @media (max-width: 760px) {
      .grid { grid-template-columns: 1fr; }
    }

    @keyframes reveal {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <p class="brand">Portfolio Panel</p>
      <p class="welcome">Welcome, <strong><%= auth.name || 'Admin' %></strong></p>

      <nav class="menu">
        <a href="/dashboard" class="<%= activeMenu === 'dashboard' ? 'active' : '' %>">Dashboard</a>
        <a href="/dashboard/projects/add" class="<%= activeMenu === 'projects-add' ? 'active' : '' %>">Add Project</a>
        <a href="/dashboard/projects" class="<%= activeMenu === 'projects' ? 'active' : '' %>">Manage Projects</a>
        <a href="/dashboard/skills/add" class="<%= activeMenu === 'skills-add' ? 'active' : '' %>">Add Skill</a>
        <a href="/dashboard/skills" class="<%= activeMenu === 'skills' ? 'active' : '' %>">Manage Skills</a>
        <a href="/dashboard/timelines/add" class="<%= activeMenu === 'timelines-add' ? 'active' : '' %>">Add Timeline</a>
        <a href="/dashboard/timelines" class="<%= activeMenu === 'timelines' ? 'active' : '' %>">Manage Timelines</a>
        <a href="/dashboard/messages" class="<%= activeMenu === 'messages' ? 'active' : '' %>">Messages</a>
        <a href="/dashboard/uploads" class="<%= activeMenu === 'uploads' ? 'active' : '' %>">Uploads</a>
        <a href="/dashboard/socials/add" class="<%= activeMenu === 'socials-add' ? 'active' : '' %>">Add Social</a>
        <a href="/dashboard/socials" class="<%= activeMenu === 'socials' ? 'active' : '' %>">Manage Social</a>
        <a href="/dashboard/profile" class="<%= activeMenu === 'profile' ? 'active' : '' %>">Edit Profile</a>
      </nav>

      <form method="POST" action="/api/auth/logout">
        <button class="logout" type="submit">Logout</button>
      </form>
    </aside>

    <main class="main">
