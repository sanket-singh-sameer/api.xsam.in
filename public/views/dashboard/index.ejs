<%- include('partials/shell-start') %>

<section class="card">
  <h1>Dashboard</h1>
  <p class="meta">Overview of your portfolio data.</p>

  <div class="grid">
    <article class="card">
      <h3>Total Projects</h3>
      <p class="meta"><%= stats.projectsCount %></p>
    </article>

    <article class="card">
      <h3>Total Skills</h3>
      <p class="meta"><%= stats.skillsCount %></p>
    </article>

    <article class="card">
      <h3>Total Timelines</h3>
      <p class="meta"><%= stats.timelinesCount %></p>
    </article>

    <article class="card">
      <h3>Total Messages</h3>
      <p class="meta"><%= stats.messagesCount %></p>
    </article>

    <article class="card">
      <h3>Total Socials</h3>
      <p class="meta"><%= stats.socialsCount %></p>
    </article>
  </div>
</section>

<%- include('partials/shell-end') %>
